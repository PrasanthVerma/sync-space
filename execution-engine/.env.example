# Execution Engine — Environment Variables
# Copy this to .env for local dev. On Railway, set these in the dashboard.

# The port the Express server listens on.
# Railway injects PORT automatically — leave this unset on Railway.
PORT=4000

# Allowed origins for CORS (comma-separated if multiple).
# Set to your Vercel client URL in production.
# CORS_ORIGIN=https://your-client.vercel.app
